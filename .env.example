# Google Calendar Integration (Service Account)
# Get these from Google Cloud Console → IAM & Admin → Service Accounts
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Booking Notification Webhook (optional fallback)
# Set to a Slack/Discord/Make webhook URL to also receive notifications
# BOOKING_WEBHOOK_URL=

# Contact email
CONTACT_EMAIL=tech.gileara@gmail.com

# Maintenance Mode
# Set MAINTENANCE_MODE=1 to reroute all page traffic to /maintenance
# Set MAINTENANCE_BYPASS_SECRET to a secure random string for admin access
# Bypass: document.cookie = "__maintenance_bypass=<secret>; path=/"
MAINTENANCE_MODE=
MAINTENANCE_BYPASS_SECRET=
